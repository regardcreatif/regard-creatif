  function correctFautes(text) {
    let words = text.split(" ");
    for (let i = 0; i < words.length; i++) {
      for (let [correct, fautes] of Object.entries(FAUTES)) {
        if (fautes.includes(words[i])) {
          words[i] = correct;
        }
      }
    }
    return words.join(" ");
  }

  // ══════════════════════════════════════════════════════════
  // DÉTECTION DU SUJET
  // ══════════════════════════════════════════════════════════

  function findTopic(question) {
    let q = correctFautes(question);
    q = normalize(q);

    if (/^(bonjour|salut|hello|coucou|bjr|bonsoir|hey|slt|cc|yo|wsh)\b/.test(q)) return "salutation";
    if (/^(merci|thanks|thx|mer6|mci|mrci)\b/.test(q)) return "remerciement";

    for (let mapping of KEYWORDS_MAP) {
      for (let kw of mapping.keywords) {
        if (q.includes(normalize(kw))) {
          return mapping.topic;
        }
      }
    }

    if (q.includes("comment faire un bon marketing") || q.includes("reussir marketing")) return "guide global";
    if (q.includes("c est quoi le marketing") || q.includes("definition marketing")) return "marketing digital";

    return null;
  }

  // ══════════════════════════════════════════════════════════
  // CONSTRUCTION DES RÉPONSES
  // ══════════════════════════════════════════════════════════

  function buildAnswerHtml(topicKey) {
    if (topicKey === "salutation") {
      return `<p>👋 Bonjour ! Je suis votre <strong>Digital Coach</strong>. Je peux vous aider sur le marketing digital, la vidéo, la photo, la gestion d'entreprise, le business, la création de contenu ou la technique web. Posez-moi votre question !</p>`;
    }
    if (topicKey === "remerciement") {
      return `<p>Avec plaisir ! 🌟 N'hésitez pas si vous avez d'autres questions. Je suis là pour vous aider à progresser dans votre parcours digital et entrepreneurial.</p>`;
    }
    if (topicKey === "guide global") {
      return `<div class="em-title">📘 Comment faire un bon marketing digital ?</div>
<p>Un bon marketing digital repose sur <strong>5 étapes clés</strong> :</p>
<p>1️⃣ <strong>Analyse et diagnostic</strong> : Qui est votre client idéal ? Quels sont ses besoins, ses habitudes numériques ? Quel est votre avantage concurrentiel ? Utilisez le SWOT et les personas.</p>
<p>2️⃣ <strong>Stratégie</strong> : Choisissez les bons canaux (SEO, réseaux sociaux, email, SEA) et le message adapté à votre public. Le copywriting et le storytelling sont vos alliés.</p>
<p>3️⃣ <strong>Outils et contenu</strong> : Créez un blog central, des vidéos, des visuels pour réseaux sociaux. Pensez multi-moment : soyez cohérent sur tous les points de contact (Instagram, site, WhatsApp, boutique).</p>
<p>4️⃣ <strong>Exécution</strong> : Publiez régulièrement, engagez votre communauté, lancez des campagnes (SEA, social ads, email automation). Testez et itérez.</p>
<p>5️⃣ <strong>Mesure et ajustement</strong> : Utilisez les analytics (Google Analytics 4) pour suivre vos KPIs (CAC, ROAS, LTV, taux de conversion) et améliorez continuellement avec le CRO.</p>
<p>💡 <em>N'oubliez pas la psychologie de l'acheteur : preuve sociale, rareté, réciprocité, autorité, cohérence. Et surtout, évitez les 3 erreurs : se projeter, laisser le financier dicter, tomber dans la routine.</em></p>
<hr><p>🔗 Explorer :</p>`;
    }
    const data = KNOWLEDGE[topicKey];
    if (!data) return "<p>❌ Désolé, cette notion n'est pas encore dans ma base de connaissances. Essayez un autre thème ou reformulez votre question.</p>";
    const safeDef = esc(data.definition);
    const safeDetails = esc(data.details);
    const safeExample = esc(data.example);
    let html = `
      <div class="em-title">📘 Définition</div>
      <p>${safeDef}</p>
      <div class="em-title" style="margin-top:12px;">📝 Explication détaillée</div>
      <p>${safeDetails}</p>
      <div class="em-title" style="margin-top:12px;">💡 Exemple concret</div>
      <p>${safeExample}</p>
      <hr>
      <div style="font-size:0.85rem; margin: 8px 0 4px;">🔗 Explorer des sujets liés :</div>
      <div class="related-buttons" id="related-buttons-${topicKey.replace(/\s/g, '')}"></div>
    `;
    return html;
  }

  function attachRelatedButtons(topicKey, containerElement) {
    if (topicKey === "guide global") {
      const defaultRelated = ["strategie marketing", "diagnostic", "psychologie acheteur", "marketing digital", "multimoment", "analytics", "cro", "growth hacking"];
      const relatedContainer = containerElement.querySelector(`.related-buttons`);
      if (relatedContainer) {
        relatedContainer.innerHTML = "";
        for (let relKey of defaultRelated) {
          const relData = KNOWLEDGE[relKey];
          if (relData) {
            const btn = document.createElement("button");
            btn.className = "related-btn";
            btn.innerText = relData.name || relKey;
            btn.onclick = () => askTopicDirectly(relKey);
            relatedContainer.appendChild(btn);
          }
        }
      }
      return;
    }
    const data = KNOWLEDGE[topicKey];
    if (!data || !data.related) return;
    const relatedContainer = containerElement.querySelector(`.related-buttons`);
    if (!relatedContainer) return;
    relatedContainer.innerHTML = "";
    for (let relTopicKey of data.related) {
      const relData = KNOWLEDGE[relTopicKey];
      if (relData) {
        const btn = document.createElement("button");
        btn.className = "related-btn";
        btn.innerText = relData.name || relTopicKey;
        btn.onclick = () => askTopicDirectly(relTopicKey);
        relatedContainer.appendChild(btn);
      }
    }
  }

  // ══════════════════════════════════════════════════════════
  // LOGIQUE DE CHAT
  // ══════════════════════════════════════════════════════════

  let isWaiting = false;
  const chatContainer = document.getElementById("chatContainer");
  const userInput = document.getElementById("userInput");
  const sendBtn = document.getElementById("sendBtn");

  function addUserMessage(text) {
    const msgDiv = document.createElement("div");
    msgDiv.className = "message user";
    msgDiv.innerHTML = `<div class="bubble">${esc(text)}</div><div class="timestamp">👤 Vous · ${new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</div>`;
    chatContainer.appendChild(msgDiv);
    scrollToBottom();
  }

  function addAgentMessage(htmlContent, topicKeyForRelated = null) {
    const msgDiv = document.createElement("div");
    msgDiv.className = "message agent";
    const bubbleDiv = document.createElement("div");
    bubbleDiv.className = "bubble";
    bubbleDiv.innerHTML = htmlContent;
    msgDiv.appendChild(bubbleDiv);
    const timeSpan = document.createElement("div");
    timeSpan.className = "timestamp";
    timeSpan.innerText = `🤖 Coach · ${new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}`;
    msgDiv.appendChild(timeSpan);
    chatContainer.appendChild(msgDiv);
    scrollToBottom();
    if (topicKeyForRelated) {
      attachRelatedButtons(topicKeyForRelated, bubbleDiv);
    }
    return msgDiv;
  }

  function scrollToBottom() {
    setTimeout(() => { chatContainer.scrollTop = chatContainer.scrollHeight; }, 30);
  }

  let typingDiv = null;
  function showTyping() {
    if (typingDiv) removeTyping();
    typingDiv = document.createElement("div");
    typingDiv.className = "message agent";
    typingDiv.innerHTML = `<div class="typing-indicator"><span></span><span></span><span></span><span style="margin-left:6px; font-size:0.75rem;">Le coach réfléchit...</span></div>`;
    chatContainer.appendChild(typingDiv);
    scrollToBottom();
  }
  function removeTyping() {
    if (typingDiv) { typingDiv.remove(); typingDiv = null; }
  }

  async function getResponseForQuestion(questionText) {
    const normalizedQuestion = questionText.trim();
    if (!normalizedQuestion) return { html: "Posez une question précise pour que je puisse vous aider." };
    const topic = findTopic(normalizedQuestion);
    if (topic) {
      return { html: buildAnswerHtml(topic), topicKey: topic };
    } else {
      const suggestions = Object.keys(KNOWLEDGE).slice(0, 10).map(k => KNOWLEDGE[k].name).join(", ");
      return { html: `<p>🤔 Je n'ai pas trouvé de sujet correspondant à "<strong>${esc(normalizedQuestion)}</strong>".</p><p>💡 Voici des sujets sur lesquels je peux vous aider : ${esc(suggestions)}...<br>Essayez de reformuler ou cliquez sur un thème ci-dessus.</p>`, topicKey: null };
    }
  }

  async function sendMessage(userText) {
    if (isWaiting) return;
    if (!userText.trim()) return;
    isWaiting = true;
    sendBtn.disabled = true;
    userInput.disabled = true;
    addUserMessage(userText);
    userInput.value = "";
    showTyping();
    await new Promise(r => setTimeout(r, 450));
    const responseObj = await getResponseForQuestion(userText);
    removeTyping();
    addAgentMessage(responseObj.html, responseObj.topicKey);
    isWaiting = false;
    sendBtn.disabled = false;
    userInput.disabled = false;
    userInput.focus();
    scrollToBottom();
  }

  function askTopicDirectly(topicKey) {
    const topicData = KNOWLEDGE[topicKey];
    if (!topicData) return;
    const questionPhrase = `Explique-moi ${topicData.name}`;
    sendMessage(questionPhrase);
  }

  function buildTopicsBar() {
    const topicsBar = document.getElementById("topicsBar");
    topicsBar.innerHTML = "";
    const categories = [
      { key: "marketing digital", icon: "📊" },
      { key: "seo", icon: "🔍" },
      { key: "sea", icon: "💰" },
      { key: "reseaux sociaux", icon: "📱" },
      { key: "strategie marketing", icon: "🎯" },
      { key: "psychologie acheteur", icon: "🧠" },
      { key: "growth hacking", icon: "🚀" },
      { key: "cro", icon: "📈" },
      { key: "storytelling", icon: "📖" },
      { key: "personal-branding", icon: "👤" },
      { key: "videographie", icon: "🎥" },
      { key: "photographie", icon: "📷" },
      { key: "design-graphique", icon: "🎨" },
      { key: "videos-courtes", icon: "⚡" },
      { key: "podcasting", icon: "🎙️" },
      { key: "business-plan", icon: "📋" },
      { key: "gestion-equipe", icon: "👥" },
      { key: "productivite", icon: "⏱️" },
      { key: "wordpress", icon: "🔧" },
      { key: "referencement-technique", icon: "⚙️" },
      { key: "gestion entreprise", icon: "🏢" },
      { key: "ethique marketing", icon: "⚖️" }
    ];
    for (let cat of categories) {
      if (KNOWLEDGE[cat.key]) {
        const btn = document.createElement("button");
        btn.className = "topic-btn";
        btn.innerHTML = `${cat.icon} ${KNOWLEDGE[cat.key].name}`;
        btn.addEventListener("click", () => askTopicDirectly(cat.key));
        topicsBar.appendChild(btn);
      }
    }
  }

  function onSend() {
    const text = userInput.value.trim();
    if (text) sendMessage(text);
  }

  sendBtn.addEventListener("click", onSend);
  userInput.addEventListener("keypress", (e) => {
    if (e.key === "Enter" && !isWaiting) {
      e.preventDefault();
      onSend();
    }
  });

  buildTopicsBar();
  scrollToBottom();
})();
</script>
